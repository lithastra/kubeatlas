{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kubeatlas.lithastra.com/schemas/helm-values-v0.1.0.json",
  "title": "kubeatlas Helm values",
  "description": "Phase 1 §2.3 secure-default invariants are enforced here. A user who wants to weaken any of them must touch multiple values; that friction is the point.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository", "pullPolicy"]
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": {
          "description": "Hard-pinned to true. Phase 1 §2.3 secure default.",
          "type": "boolean",
          "const": true
        }
      },
      "required": ["runAsNonRoot"]
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security. The spec hard-pins runAsNonRoot, readOnlyRootFilesystem, allowPrivilegeEscalation, and capabilities.drop=[ALL].",
      "properties": {
        "runAsNonRoot": { "type": "boolean", "const": true },
        "readOnlyRootFilesystem": { "type": "boolean", "const": true },
        "allowPrivilegeEscalation": { "type": "boolean", "const": false },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": {
              "type": "array",
              "items": { "type": "string" },
              "contains": { "const": "ALL" }
            }
          },
          "required": ["drop"]
        }
      },
      "required": [
        "runAsNonRoot",
        "readOnlyRootFilesystem",
        "allowPrivilegeEscalation",
        "capabilities"
      ]
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "description": "ClusterIP only. NodePort and LoadBalancer are intentionally rejected — exposure goes through Ingress (with auth).",
          "type": "string",
          "const": "ClusterIP"
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["type", "port", "containerPort"]
    },
    "ingress": {
      "type": "object",
      "description": "Disabled by default. Enabling it requires explicit acknowledgement that authentication is provided by an external layer (oauth2-proxy / Pomerium / Cloudflare Access / SSO at the Ingress controller).",
      "properties": {
        "enabled": { "type": "boolean" },
        "acknowledgeNoBuiltinAuth": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      },
      "required": ["enabled"],
      "if": {
        "properties": {
          "enabled": { "const": true }
        },
        "required": ["enabled"]
      },
      "then": {
        "properties": {
          "acknowledgeNoBuiltinAuth": { "const": true }
        },
        "required": ["acknowledgeNoBuiltinAuth"]
      }
    },
    "resources": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "persistence": {
      "type": "object",
      "description": "Persistence (Tier 2 / PostgreSQL + Apache AGE) lands in v1.0. v0.1.0 forces it disabled.",
      "properties": {
        "enabled": { "type": "boolean", "const": false }
      },
      "required": ["enabled"]
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressNamespaceLabel": { "type": "string" }
      }
    },
    "extraLabels": { "type": "object" }
  },
  "required": ["image", "service", "ingress", "podSecurityContext", "securityContext", "persistence"]
}
