{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kubeatlas.lithastra.com/schemas/helm-values-v0.1.0.json",
  "title": "kubeatlas Helm values",
  "description": "Phase 1 §2.3 secure-default invariants are enforced here. A user who wants to weaken any of them must touch multiple values; that friction is the point.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository", "pullPolicy"]
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "podSecurityContext": {
      "type": "object",
      "properties": {
        "runAsNonRoot": {
          "description": "Hard-pinned to true. Phase 1 §2.3 secure default.",
          "type": "boolean",
          "const": true
        }
      },
      "required": ["runAsNonRoot"]
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security. The spec hard-pins runAsNonRoot, readOnlyRootFilesystem, allowPrivilegeEscalation, and capabilities.drop=[ALL].",
      "properties": {
        "runAsNonRoot": { "type": "boolean", "const": true },
        "readOnlyRootFilesystem": { "type": "boolean", "const": true },
        "allowPrivilegeEscalation": { "type": "boolean", "const": false },
        "capabilities": {
          "type": "object",
          "properties": {
            "drop": {
              "type": "array",
              "items": { "type": "string" },
              "contains": { "const": "ALL" }
            }
          },
          "required": ["drop"]
        }
      },
      "required": [
        "runAsNonRoot",
        "readOnlyRootFilesystem",
        "allowPrivilegeEscalation",
        "capabilities"
      ]
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "description": "ClusterIP only. NodePort and LoadBalancer are intentionally rejected — exposure goes through Ingress (with auth).",
          "type": "string",
          "const": "ClusterIP"
        },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["type", "port", "containerPort"]
    },
    "ingress": {
      "type": "object",
      "description": "Disabled by default. Enabling it requires explicit acknowledgement that authentication is provided by an external layer (oauth2-proxy / Pomerium / Cloudflare Access / SSO at the Ingress controller).",
      "properties": {
        "enabled": { "type": "boolean" },
        "acknowledgeNoBuiltinAuth": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      },
      "required": ["enabled"],
      "if": {
        "properties": {
          "enabled": { "const": true }
        },
        "required": ["enabled"]
      },
      "then": {
        "properties": {
          "acknowledgeNoBuiltinAuth": { "const": true }
        },
        "required": ["acknowledgeNoBuiltinAuth"]
      }
    },
    "resources": { "type": "object" },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "persistence": {
      "type": "object",
      "description": "Persistence (Tier 2 / PostgreSQL + Apache AGE). Default-off so zero-config installs stay on Tier 1. When enabled, exactly one of {embedded.enabled=true, connection.host non-empty} must be set: schema rejects both unset (half-configured) and both set (ambiguous wiring).",
      "properties": {
        "enabled": { "type": "boolean" },
        "embedded": {
          "type": "object",
          "properties": {
            "enabled":          { "type": "boolean" },
            "storageSize":      { "type": "string", "minLength": 1 },
            "storageClassName": { "type": "string" },
            "image":            { "type": "string", "minLength": 1 },
            "clusterNameSuffix": {
              "type": "string",
              "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
            }
          }
        },
        "connection": {
          "type": "object",
          "properties": {
            "host":     { "type": "string" },
            "port":     { "type": "integer", "minimum": 1, "maximum": 65535 },
            "database": { "type": "string", "minLength": 1 },
            "user":     { "type": "string", "minLength": 1 },
            "password": { "type": "string" },
            "passwordSecretRef": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "key":  { "type": "string", "minLength": 1 }
              }
            },
            "sslMode": {
              "type": "string",
              "enum": ["disable", "require", "verify-ca", "verify-full"]
            }
          }
        }
      },
      "required": ["enabled"],
      "allOf": [
        {
          "comment": "When persistence is enabled, embedded.enabled=true and connection.host non-empty are mutually exclusive. Schema rejects setting both.",
          "if": {
            "properties": {
              "enabled": { "const": true },
              "embedded": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              }
            },
            "required": ["enabled", "embedded"]
          },
          "then": {
            "properties": {
              "connection": {
                "properties": {
                  "host": { "type": "string", "maxLength": 0 }
                }
              }
            }
          }
        },
        {
          "comment": "When persistence is enabled and embedded is off, connection.host must be non-empty.",
          "if": {
            "properties": {
              "enabled": { "const": true },
              "embedded": {
                "properties": { "enabled": { "const": false } }
              }
            },
            "required": ["enabled"]
          },
          "then": {
            "properties": {
              "connection": {
                "type": "object",
                "properties": {
                  "host": { "type": "string", "minLength": 1 }
                },
                "required": ["host"]
              }
            },
            "required": ["connection"]
          }
        }
      ]
    },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressNamespaceLabel": { "type": "string" }
      }
    },
    "extraLabels": { "type": "object" }
  },
  "required": ["image", "service", "ingress", "podSecurityContext", "securityContext", "persistence"]
}
