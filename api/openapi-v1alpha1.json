        "operationId": "get_api_v1alpha1_rbac_role_namespace_name_subjects",
        "parameters": [
          {
            "in": "path",
            "name": "namespace",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
