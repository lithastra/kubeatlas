    "version": "v1alpha1"
  },
  "openapi": "3.0.3",
  "paths": {
    "/api/v1alpha1/blast-radius/{namespace}/{kind}/{name}": {
      "get": {
        "description": "Returns every resource reachable by walking incoming edges from the target — i.e. everything that would be impacted if this resource were deleted or broken. Use the underscore '_' as namespace for cluster-scoped resources. P2-T15 (F-110).",
        "operationId": "get_api_v1alpha1_blast-radius_namespace_kind_name",
        "parameters": [
          {
            "description": "Namespace (use '_' for cluster-scoped)",
            "in": "path",
            "name": "namespace",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "kind",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "name",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Path-length cap; default 5, hard max 10",
            "in": "query",
            "name": "max_depth",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "description": "Comma-separated edge labels to follow; empty = any",
            "in": "query",
            "name": "edge_types",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Include the start resource in the result set; default false",
            "in": "query",
            "name": "include_source",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BlastRadiusResponse"
                }
              }
            },
            "description": "Affected resources"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid request (missing or malformed parameters)"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Resource not found"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "summary": "Transitive set of resources affected by changes to this resource"
      }
    },
    "/api/v1alpha1/cycles": {
      "get": {
        "description": "Returns every SCC of two or more resources. In a healthy cluster the list is empty; non-empty results indicate cyclic dependencies (e.g. ConfigMaps that reference each other). P2-T18 (F-112 part 2).",
        "operationId": "get_api_v1alpha1_cycles",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CyclesResponse"
                }
              }
            },
            "description": "Cycle reports"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid request (missing or malformed parameters)"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Resource not found"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "summary": "Strongly connected components of size \u003e= 2"
      }
    },
    "/api/v1alpha1/graph": {
      "get": {
        "description": "Returns an aggregated View at one of four levels: cluster, namespace, workload, resource. Workload and resource scopes require namespace+kind+name; namespace requires namespace.",
        "operationId": "get_api_v1alpha1_graph",
        "parameters": [
          {
            "description": "Aggregation level",
            "in": "query",
            "name": "level",
            "required": true,
            "schema": {
              "enum": [
                "cluster",
                "namespace",
                "workload",
                "resource"
              ],
              "type": "string"
            }
          },
          {
            "description": "Namespace; required for namespace/workload/resource",
            "in": "query",
            "name": "namespace",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Resource Kind; required for workload/resource",
            "in": "query",
            "name": "kind",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Resource name; required for workload/resource",
            "in": "query",
            "name": "name",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/View"
                }
              }
            },
            "description": "Aggregated graph view"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Invalid request (missing or malformed parameters)"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Resource not found"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": "Internal server error"
          }
        },
        "summary": "Graph at a given level"
      }
    },
